{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "outDir": "dist",
        "types": [
            "vitest/globals",
            "vitest/importMeta",
            "vite/client",
            "node",
            "jest",
            "vitest",
            "@testing-library/jest-dom",
            "@testing-library/jest-dom/jest-globals"
        ]
    },
    "include": [
        "vite.config.ts",
        "rollup.config.js",
        "src/**/*.test.ts",
        "src/**/*.spec.ts",
        "src/**/*.test.tsx",
        "src/**/*.spec.tsx",
        "src/**/*.test.js",
        "src/**/*.spec.js",
        "src/**/*.test.jsx",
        "src/**/*.spec.jsx",
        "src/**/*.d.ts"
    ],
    "typeRoots": ["./node_modules/@types", "./node_modules"],
    "exclude": ["node_modules", "./cypress.config.ts", "cypress"]
}
