{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"],
            "@semoss/ui": ["../../libs/ui/src/index.ts"],
            "@semoss/renderer": ["../../libs/renderer/src/index.ts"],
            "@semoss/sdk": ["../../libs/sdk/src/index.ts"]
        },
        "target": "es6",
        "lib": ["dom", "dom.iterable", "esnext"],
        "allowJs": true,
        "skipLibCheck": true,
        "strict": false,
        "forceConsistentCasingInFileNames": true,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "react-jsx",
        "incremental": true,
        "experimentalDecorators": true,
        "outDir": "./dist",
        "types": ["vitest/globals", "@testing-library/jest-dom/vitest"]
    },
    "include": ["./src", "./global.d.ts", "./src/testing"],
    "exclude": [
        "./plugins/**/*",
        "./typings/**/*",
        "./dist/**/*",
        "../../libs/renderer/src/store/state/migration"
    ]
}
