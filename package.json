{
    "private": true,
    "name": "semoss",
    "description": "SEMOSS Analytics Platform",
    "scripts": {
        "preinstall": "npx only-allow pnpm",
        "prepare": "husky install",
        "fix": "pnpm run --filter=@semoss/legacy --filter=@semoss/ui --filter=@semoss/client fix",
        
        "dev": "npx nx run-many -t dev -p @semoss/ui @semoss/sdk @semoss/renderer @semoss/client @semoss/legacy",
        "dev:client": "nx run @semoss/client:dev",
        "dev:legacy": "nx run @semoss/legacy:dev",
        "dev:example": "nx run @semoss/example:dev",
        "dev:ui": "echo \"TODO: start script to run component library, so we don't have to cd to ./libs/ui\"",

        "nx:dep-graph": "nx dep-graph",
        "nx:reset": "nx reset",
        "nx:generate-react-lib": "echo \"TODO: create a nx generator for react rollup/webpack library\"",

        "build": "npx nx run-many -t build -p @semoss/client @semoss/legacy",

        "test": "vitest --watch=false --passWithNoTests --changed",
        "lint:client": "npx nx lint @semoss/client",
        "lint:ui": "npx nx lint @semoss/ui",
        "lint:renderer": "npx nx lint @semoss/renderer",
        "lint:all": "echo \"TODO: fix lint script to lint all packages/libs .\""
    },
    "author": "",
    "license": "Apache-2.0",
    "devDependencies": {
        "@commitlint/cli": "^17.7.0",
        "@commitlint/config-conventional": "^17.7.0",
        "@nx/cypress": "20.2.2",
        "@nx/eslint": "20.2.2",
        "@nx/eslint-plugin": "20.2.2",
        "@nx/jest": "20.2.2",
        "@nx/js": "20.2.2",
        "@nx/react": "20.2.2",
        "@nx/rollup": "20.2.2",
        "@nx/storybook": "20.2.2",
        "@nx/vite": "19.8.4",
        "@nx/web": "20.2.2",
        "@nx/webpack": "20.2.2",
        "@nx/workspace": "20.2.2",
        "@rollup/plugin-url": "^8.0.2",
        "@svgr/rollup": "^8.1.0",
        "@swc-node/register": "~1.9.1",
        "@swc/core": "~1.5.7",
        "@swc/helpers": "~0.5.11",
        "@testing-library/jest-dom": "^6.6.3",
        "@types/jest": "^29.5.14",
        "@types/node": "18.16.9",
