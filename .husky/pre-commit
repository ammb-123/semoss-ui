#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Linting @semoss/client
npx nx lint @semoss/client || {
  echo "ERROR: Linting issues were found in the packages/client. Please address them before proceeding."
  exit 1
}

# Linting @semoss/ui
npx nx lint @semoss/ui || {
  echo "ERROR: Linting issues were found in the libs/ui. Please address them before proceeding."
  exit 1
}

# Linting @semoss/renderer
# npx nx lint @semoss/renderer || {
#   echo "ERROR: Linting issues were found in the libs/renderer. Please address them before proceeding."
#   exit 1
# }

# Testing all projects/libs if vite config is present
npx vitest --watch=false --passWithNoTests --changed || {
  echo "ERROR: Testing issues were found in the committed files. Please address them before proceeding."
  exit 1
}

